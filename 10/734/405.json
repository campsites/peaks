tion":[35.1041424,78.2993914],"tp":"SU","ts":"2024-05-13T09:12:03Z","tags":{"ele":"6433","name":"大园山","name:en":"Dayuan","name:zh-Latn-pinyin":"Dàyuán Shān","note":"罗马字母拼写 Dàyuán Shān 地名来历 因此山形似一个大园子，所以将其命名为大园山。 地名含义 “大园山”，汉语，意为像一座大园子的山。”山“意为陆地上由土、石形成的高耸的部分。 历史沿革 1983年第一次地名普查使用此地名，一直沿用至今。"}},"13272146654":{"location":[35.0306338,78.1582994],"tp":"SU","ts":"2025-10-31T12:25:03Z","tags":{"name":"石峡"}},"13272146656":{"location":[35.1140126,78.2537366],"tp":"SU","ts":"2025-10-31T12:25:03Z","tags":{"name":"天河岭"}},"13272146657":{"location":[35.1328537,78.2896151],"tp":"SU","ts":"2025-10-31T12:25:03Z","tags":{"name":"小红山"}},"13272146659":{"location":[35.0754389,78.308623],"tp":"SU","ts":"2025-10-31T12:25:03Z","tags":{"name":"半头崖"}},"13272146660":{"location":[35.0534196,78.3571686],"tp":"SU","ts":"2025-10-31T12:25:03Z","tags":{"name":"场北顶"}},"13272146661":{"location":[35.0160902,78.3658275],"tp":"SU","ts":"2025-10-31T12:25:03Z","tags":{"name":"场南顶"}}}