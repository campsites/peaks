{"3213727594":{"location":[28.439403,98.6843785],"tp":"SU","tags":{"alt_name":"卡瓦格博;喀瓦格博;卡瓦格博雪山;太子峰;太子雪山;梅里雪山;梅里主峰;念青卡瓦格博;绒赞卡瓦格博;阿尼卡瓦格博","alt_name:zh":"卡瓦格博;喀瓦格博;卡瓦格博雪山;太子峰;太子雪山;梅里雪山;梅里主峰;念青卡瓦格博;绒赞卡瓦格博;阿尼卡瓦格博","description":"藏语意为白雪之峰。在藏文经典中常称之为“绒赞卡瓦格博”。“绒”意为河谷地带，“赞”为神灵名，有强大、险峻之意，连起来即为“河谷地带险峻雄伟的白雪山峰”。","ele":"6740","name":"卡瓦格博峰","name:bo":"ཁ་བ་དཀར་པོ།","name:en":"Kawagarbo","name:zh":"卡瓦格博峰","prominence":"2230","source:prominence":"6740-4510 (Col beside Lang La)","wikidata":"Q621247","wikipedia":"zh:卡瓦格博峰"}},"3213727595":{"location":[28.5127564,98.6065416],"tp":"SU","tags":{"alt_name:en":"Cogar Laka;Kawagarbo II","alt_name:zh":"措格腊卡;卡瓦格博II峰;确达玛峰;狮子座雪山;贡该僧格那宗;僧格那宗","ele":"6509","name":"错改腊卡","name:bo":"མཚོ་ཀོང་ལ་ཁ།","name:en":"Cogar Lapka","name:zh":"错改腊卡"}},"3213731835":{"location":[28.33474,98.749998],"tp":"SU","tags":{"alt_name":"缅茨姆峰;面茨姆;面茨姆峰;神女峰;阿佳缅茨姆;太子雪山","alt_name:en":"Mianzimu;Mianzim;Maicomo;Main Tsunmo","alt_name:zh":"缅茨姆峰;面茨姆;面茨姆峰;神女峰;阿佳缅茨姆;太子雪山","description":"藏语意为“大海神女”，相传是卡瓦格博的妻子。","ele":"6054","name":"缅茨姆","name:bo":"སྣད་མཚོ་མོ།","name:en":"Mount Men Tsunmo","name:zh":"缅茨姆"}},"3810813209":{"location":[28.3916867,98.7193979],"tp":"SU","tags":{"alt_name":"将军峰，卡瓦绒达;卡瓦让达;玛奔巴乌杜杰;巴乌八蒙;笑农;乌格冬;巴乌帕崇","alt_name:en":"Khawa Rangdak","alt_name:zh":"将军峰，卡瓦绒达;卡瓦让达;玛奔巴乌杜杰;巴乌八蒙;笑农;乌格冬;巴乌帕崇","description":"雨崩地区称其为卡瓦绒达，传说为卡瓦格博神的侍从；藏区普遍接受巴乌巴莫，指藏传佛教中的兽面勇男（巴乌）与勇女（巴莫）组合；更有玛奔巴乌杜吉之说，意为\"具力勇将\"。","ele":"6000","name":"巴乌巴莫","name:en":"Mount Pawo Pamo"}},"3810813210":{"location":[28.4833786,98.6760145],"tp":"SU","tags":{"alt_name:en":"Magboin Drandul Wangchyuk","alt_name:zh":"沾迪吾修;玛兵扎拉旺堆;马兵扎堆吾学;占堆吾学;玛兵扎堆旺秋","description":"无敌降魔战神峰，又名将军峰、黑头将军","ele":"6365","name":"扎堆吾学","name:en":"Mount Dradul Wangchuk"}},"3810813211":{"location":[28.3580964,98.7352602],"tp":"SU","tags":{"alt_name:en":"Gyalwa Rignga","alt_name:zh":"加瓦仁安;吉瓦林安;甲瓦林安;甲娃仁阿;甲瓦仁阿;五方佛峰;五冠峰","description":"藏语意为“五佛之冠”，西藏境内叫“无头魔鬼峰”。因此山并列地排立着五个扁平而尖削的雪峰，很像菩萨戴的五佛冠帽，故名。位于缅茨姆峰北侧并与之相连。","ele":"5470","name":"吉娃仁安","name:bo":"རྒྱལ་བ་རིགས་ལྔ།","name:en":"Mount Gyalwa Riknga","name:zh":"吉娃仁安"}},"8737203620":{"location":[28.5562216,98.6356147],"tp":"SU","tags":{"note":"此峰不是说拉赞归面布，准确地点应在说拉垭口附近"}},"8737203621":{"location":[28.4739007,98.6780608],"tp":"SU","tags":{"alt_name:en":"Chushwa Lakha;Tshokong Lakha","alt_name:zh":"曲刷拉卡;粗归腊卡;拉贡拉卡","description":"藏语意为圆湖上方的山峰，位于斯农冰川的冰斗上方，山峰的形状很像踞据的黑熊的爪子","ele":"5993","name":"茨霜腊卡/ ཆུ་ཤྭ་ལ་ཁ།","name:bo":"ཆུ་ཤྭ་ལ་ཁ།","name:en":"Cusha Laka","name:zh":"茨霜腊卡"}},"9381675487":{"location":[28.5356902,98.5033321],"tp":"SU","tags":{"ele":"4690","name":"昔左腊卡","name:en":"Xizo Laka"}},"9381675488":{"location":[28.4820643,98.6641574],"tp":"SU","tags":{"alt_name":"来日顶卡;乃日顶卡;乃日丁卡;来日贡卡","alt_name:en":"Lairi Gongka","alt_name:zh":"来日顶卡;乃日顶卡;乃日丁卡;来日贡卡","description":"藏语意为圣山顶，传说它是扎堆吾学脱放在一旁的帽子","ele":"6379","name":"奶日顶卡","name:en":"Nairi Dengka"}},"9381675489":{"location":[28.4905132,98.6306689],"tp":"SU","tags":{"ele":"6175","name":"芒框腊卡","name:en":"Magai Laka"}},"12700456000":{"location":[28.5990505,98.5026371],"tp":"SU","tags":{"ele":"4900","prominence":"1670","source:ele":"SRTM","source:prominence":"4900-3230 (Col at the N)"}},"13056518227":{"location":[28.4211981,98.7044762],"tp":"SU","tags":{"alt_name:zh":"十六尊者峰;包乌杜吉;帕巴乃丁吉峰;帕巴尼顶九焯峰;帕巴尼顶九焯;帕巴乃丁九卓;帕巴乃丁德朵;扒巴念牵久卓","description":"藏语意为“十六尊者峰”或“神圣十六罗汉峰”。","ele":"5877","name":"帕巴乃丁吉著","name:en":"Phakpa Neten Chudruk"}},"13056521261":{"location":[28.453625,98.6983303],"tp":"SU","tags":{"alt_name:en":"Salkhyag Lakha","alt_name:zh":"布琼桑杰旺秋;布穷松吉吾学;布穹桑吉旺秋;斯恰腊卡;太子峰;王子峰","description":"藏语意为“小儿子”，传说其为卡瓦格博和缅茨姆所生的儿子。","ele":"6028","name":"布迥松阶吾学","name:en":"Buchung Sanggye Wangchyuk"}},"13056616195":{"location":[28.4275475,98.5762926],"tp":"SU","tags":{"alt_name:zh":"崩凶腊卡","ele":"5775","name":"崩匈腊卡","name:en":"Bungxung Laka"}},"13056631726":{"location":[28.3244554,98.7456876],"tp":"SU","tags":{"alt_name:zh":"努松说根;农松秋根","description":"纳松秋根是缅茨姆的忠诚内卫老臣，也有传言称其为她舅舅","ele":"5832","name":"纳松秋根","name:en":"Chugen-je","note":"“披子穆”为错误说法，是缅茨姆的变体"}},"13